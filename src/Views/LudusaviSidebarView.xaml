<UserControl x:Class="LudusaviPlaynite.Views.LudusaviSidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Foreground="{DynamicResource TextBrush}">
    <UserControl.Resources>
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="GameCard" TargetType="Border">
            <Setter Property="Background" Value="#0AFFFFFF"/>
            <Setter Property="BorderBrush" Value="#18808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Padding="16,14,16,10"
                Background="#0A808080"
                BorderBrush="#18808080" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xEF08;" FontFamily="Segoe MDL2 Assets"
                               FontSize="22" VerticalAlignment="Center"
                               Margin="0,0,10,0" Opacity="0.75"/>
                    <TextBlock Text="Ludusavi" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="Save game backup manager" 
                           FontSize="11.5" Opacity="0.5" Margin="32,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Padding="12,8"
                Background="#06808080"
                BorderBrush="#18808080" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ToolbarBtn}" Click="OpenLudusaviButton_Click"
                        ToolTip="Open Ludusavi Application">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7AC;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Open Ludusavi" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolbarBtn}" Click="BackupAllButton_Click"
                        ToolTip="Back up all games">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEF08;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Backup All" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolbarBtn}" Click="RefreshButton_Click"
                        ToolTip="Refresh backup list">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- SEARCH BAR -->
        <Border Grid.Row="2" Padding="12,6"
                Background="#04808080"
                BorderBrush="#18808080" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           VerticalAlignment="Center" HorizontalAlignment="Left"
                           Margin="8,0,0,0" Opacity="0.4" IsHitTestVisible="False"/>
                <TextBox x:Name="SearchTextBox" 
                         Padding="28,5,8,5"
                         TextChanged="SearchTextBox_TextChanged"
                         Background="#10808080" BorderBrush="#20808080"/>
            </Grid>
        </Border>

        <!-- BACKED-UP GAMES LIST -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="12,8">
            <StackPanel>
                <!-- Empty State -->
                <TextBlock x:Name="EmptyStateText" 
                           Text="No backed up games found. Use Ludusavi to create backups."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Opacity="0.4" FontSize="14" Margin="0,40,0,0"
                           Visibility="Collapsed"/>

                <!-- Loading State -->
                <StackPanel x:Name="LoadingPanel" Visibility="Collapsed" 
                            HorizontalAlignment="Center" Margin="0,40,0,0">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" 
                               FontSize="24" HorizontalAlignment="Center" Opacity="0.4"/>
                    <TextBlock Text="Loading backups..." 
                               FontSize="14" Opacity="0.4" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Games -->
                <ItemsControl x:Name="GamesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource GameCard}">
                                <DockPanel>
                                    <!-- Right side buttons -->
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource IconBtn}" Click="BackupGameButton_Click"
                                                Tag="{Binding GameName}"
                                                ToolTip="Back up this game">
                                            <TextBlock Text="&#xEF08;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                        </Button>
                                        <Button Style="{StaticResource IconBtn}" Click="RestoreGameButton_Click"
                                                Tag="{Binding GameName}"
                                                ToolTip="Restore this game">
                                            <TextBlock Text="&#xF01C;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                        </Button>
                                        <Button Style="{StaticResource IconBtn}" Click="OpenBackupFolderButton_Click"
                                                Tag="{Binding GameName}"
                                                ToolTip="Open backup folder">
                                            <TextBlock Text="&#xEC5B;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Left side info -->
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" VerticalAlignment="Center"
                                                       Margin="0,0,8,0" Opacity="0.5"/>
                                            <TextBlock Text="{Binding GameName}" FontSize="14" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                       MaxWidth="500"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="22,3,0,0">
                                            <Border Style="{StaticResource StatusBadge}" Background="#204CAF50">
                                                <TextBlock FontSize="10.5">
                                                    <Run Text="{Binding BackupCount, Mode=OneWay}"/>
                                                    <Run Text=" backups"/>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding LastBackupDate}" FontSize="11" Opacity="0.45"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- STATUS BAR -->
        <Border Grid.Row="4" Padding="16,8"
                Background="#0A808080"
                BorderBrush="#18808080" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="GameCountText" DockPanel.Dock="Left" FontSize="11.5" Opacity="0.5"/>
                <TextBlock x:Name="VersionText" DockPanel.Dock="Right" HorizontalAlignment="Right" 
                           FontSize="11.5" Opacity="0.5"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
